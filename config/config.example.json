{
  "listen": "0.0.0.0:8080",
  "upstreamBaseURL": "https://api.code.umans.ai",
  "defaultModel": "umans-coder",
  "opusModel": "umans-glm-5.2",
  "sonnetModel": "umans-coder",
  "haikuModel": "umans-flash",
  "keyConcurrencyLimit": 4,
  "keyQueueTimeout": "50s",
  "upstreamRetryMax": 2,
  "retry429": false,
  "upstreamRetryBaseDelay": "2s",
  "upstreamRetryMaxDelay": "5s",
  "schemaCompat": true,
  "catalogTTL": "10m",
  "searchMode": "exa",
  "budgetPolicy": "error",
  "errorEventDir": "error-events",
  "errorEventMaxAge": "24h",
  "errorEventMaxSize": 5242880,
  "adminPassword": "change-me",
  "proxyAccessToken": "",
  "stickySession": true,
  "stickySessionTTL": "10s"
}
